{
  "name": "activedesk",
  "version": "1.0.1",
  "description": "ActiveDesk - keep your presence active",
  "main": "electron/main.js",
  "author": "ActiveDesk",
  "license": "MIT",
  "scripts": {
    "postinstall": "node scripts/ensure-electron-runtime.js",
    "start": "electron .",
    "build:mac": "electron-builder --mac dmg zip",
    "build:win": "electron-builder --win nsis --x64",
    "build:win:appx": "electron-builder --win appx --x64",
    "build:all": "electron-builder --mac dmg zip --win nsis",
    "license:init": "node scripts/license-cli.js init",
    "license:generate": "node scripts/license-cli.js generate"
  },
  "build": {
    "appId": "com.activedesk.app",
    "productName": "ActiveDesk",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "assets/**/*",
      "electron/**/*",
      "build/icon.png",
      "icons/**/*",
      "index.html",
      "renderer.js",
      "styles.css",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "appx"
      ],
      "icon": "build/icon.png"
    },
    "appx": {
      "identityName": "KodeKenobi.ActiveDesk",
      "publisher": "CN=Ignatius Mutizwa",
      "publisherDisplayName": "Ignatius Mutizwa"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icon.icns"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3"
  },
  "allowScripts": {
    "electron@28.3.3": true
  }
}
