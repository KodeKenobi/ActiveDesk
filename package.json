{
  "name": "activedesk",
  "version": "1.0.0",
  "description": "ActiveDesk - keep your presence active",
  "main": "electron/main.js",
  "author": "ActiveDesk",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win nsis --x64"
  },
  "build": {
    "appId": "com.activedesk.app",
    "productName": "ActiveDesk",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*",
      "build/icon.png",
      "icons/**/*",
      "index.html",
      "renderer.js",
      "styles.css",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3"
  }
}
